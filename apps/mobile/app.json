{
  "expo": {
    "name": "Perx",
    "slug": "perx",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#C1D9DE",
    "splash": {
      "backgroundColor": "#013137",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Perx uses your location to show nearby benefit providers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#013137"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      [
        "expo-location",
        { "locationWhenInUsePermission": "Perx uses your location to show nearby benefit providers." }
      ]
    ]
  }
}
